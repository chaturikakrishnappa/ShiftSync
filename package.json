{
  "name": "shiftsync",
  "private": true,
  "version": "1.0.0",
  "description": "ShiftSync - Employee shift scheduling and attendance SaaS",
  "scripts": {
    "dev": "npm-run-all -p dev:backend dev:frontend",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "build": "npm-run-all -s build:backend build:frontend",
    "build:backend": "npm --prefix backend run build",
    "build:frontend": "npm --prefix frontend run build",
    "start": "npm --prefix backend run start",
    "render-build": "npm install && npm run build:backend"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "npm-run-all": "^4.1.5"
  },
  "engines": {
    "node": "20.x"
  },
  "workspaces": [
    "backend",
    "frontend"
  ]
}
