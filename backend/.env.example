# Environment Configuration Example for ShiftSync Backend

# --- SYSTEM ---
NODE_ENV=development
PORT=5000
APP_NAME=ShiftSync

# --- DATABASE ---
# MongoDB Atlas Connection String
# Example: mongodb+srv://<user>:<password>@cluster.mongodb.net/shiftsync?retryWrites=true&w=majority
# IMPORTANT: Special characters in password (like @, #) must be URL-encoded (e.g., @ as %40)
MONGODB_URI=

# --- AUTHENTICATION ---
# Random string for JWT signing
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# --- FRONTEND & CORS ---
# Local development origins and production Vercel domain
# Example: http://localhost:5173,http://localhost:5174,https://shiftsync-frontend.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
FRONTEND_URL=http://localhost:5173

# --- EMAIL (SMTP) ---
# For dev: Use Mailtrap or Ethereal
# For prod: Use SendGrid, Postmark, or AWS SES
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@shiftsync.app

# --- AI INTEGRATION ---
# Anthropic Claude API Key
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-latest

# --- AUTOMATION ---
# Set to 'true' to disable shift reminders in development
DISABLE_CRON=false
